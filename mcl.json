{
  "vars": {},
  "scripts": {
    "dev": {
      "web": "cd apps/web && ng serve --port 4200",
      "api": "cd apps/api && wrangler dev --local --port 8787"
    },
    "build": {
      "shared": "cd packages/shared && npm run build",
      "web": "cd apps/web && ng build --configuration production",
      "api": "cd apps/api && tsc --noEmit"
    },
    "test": {
      "all": "npm run test --workspaces --if-present",
      "api": "cd apps/api && vitest run",
      "web": "cd apps/web && ng test"
    },
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": {
      "api": "cd apps/api && tsc --noEmit",
      "web": "cd apps/web && ng build --configuration production"
    },
    "deploy": {
      "api": "cd apps/api && wrangler deploy",
      "ingestion": "cd apps/workers/ingestion && wrangler deploy",
      "agent-cycle": "cd apps/workers/agent-cycle && wrangler deploy",
      "generation": "cd apps/workers/generation && wrangler deploy",
      "comment": "cd apps/workers/comment && wrangler deploy",
      "memory": "cd apps/workers/memory && wrangler deploy",
      "score": "cd apps/workers/score && wrangler deploy"
    },
    "db": {
      "migrate": "wrangler d1 migrations apply arguon-db --local",
      "migrate:prod": "wrangler d1 migrations apply arguon-db"
    }
  }
}
